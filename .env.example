IMAGE_DIR=/data/images
DB_PATH=/data/birdfinder.db
API_PORT=8080

# Where the detector persists the UI-configured detection-crop region.
# Lives on the (detector-writable) data volume so it survives restarts.
CROP_CONFIG_PATH=/data/crop.json

# On-demand camera snapshot ("Test Camera" button).
# Port the detector's snapshot server listens on, and the URL the api uses to
# reach it over the compose network. The defaults work as-is; only change them
# together if you need a different port.
CAMERA_SERVER_PORT=8000
DETECTOR_URL=http://detector:8000

# Species-reference data bank (Lightbox comparison panel).
# The offline-built manifest.json + cached reference images are a large
# (~hundreds of MB) gitignored build artifact, so they are NOT baked into the
# api image — they live on the data volume alongside the images/DB. Build them
# with `python tools/build_species_reference.py` on a dev machine and copy
# `manifest.json` + `images/` into <data-volume>/species_reference/ on the host
# (e.g. /mnt/ssd/birdfinder-data/species_reference/). The api mounts the data
# volume read-only, so it finds them here. If unset/absent, every reference
# lookup 404s and the panel shows "No reference available".
SPECIES_REFERENCE_DIR=/data/species_reference

# Hardware tab — "Test network" internet speed test (Hardware page button).
# Each run downloads then uploads a small payload against a public speed-test
# endpoint and reports Mbps. Payloads are kept small to spare a limited Pi
# connection; raise them only if you need a more accurate reading on a fast
# link. The defaults (Cloudflare's __down/__up) work as-is.
# SPEEDTEST_DOWNLOAD_BYTES=1048576
# SPEEDTEST_UPLOAD_BYTES=262144
# SPEEDTEST_DOWN_URL=https://speed.cloudflare.com/__down
# SPEEDTEST_UP_URL=https://speed.cloudflare.com/__up
