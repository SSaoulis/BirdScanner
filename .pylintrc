# Pylint configuration for the BirdScanner source tree.
#
# Run as:
#   pylint birdscanner tools               # source (this file)
#   pylint tests --rcfile=tests/.pylintrc  # tests (relaxed pytest idioms)
#
# The tests use a separate rcfile only to relax pytest idioms — not for import
# resolution, which is now uniform (everything is the `birdscanner` package).
#
# The Pi-only native bindings (libcamera, picamera2) and the untyped C-extension
# / third-party libs (onnxruntime, onnx, cv2) cannot be analysed off-device, so
# their import/no-member noise is silenced here exactly as mypy.ini silences it.

[MAIN]
# Native / Pi-only / untyped modules that cannot be imported on a dev machine.
ignored-modules=libcamera,
                picamera2,
                picamera2.devices,
                picamera2.devices.imx500,
                onnxruntime,
                onnxruntime.quantization,
                onnx,
                torch,
                ultralytics,
                model_compression_toolkit,
                edgemdt_tpc

[MESSAGES CONTROL]
disable=too-few-public-methods,
        import-outside-toplevel,
        broad-exception-caught,
        global-statement,

[FORMAT]
max-line-length=100

[DESIGN]
max-args=5
max-attributes=15

[TYPECHECK]
# cv2's members are populated dynamically at runtime, so pylint can't see them.
generated-members=cv2.*
