# Deploy settings for deploy.ps1 (redeploy the Pi's docker-compose stack over SSH).
# Copy this file to `deploy.env` (git-ignored) and fill in the values.
# Every key below can also be supplied as a real environment variable, which
# takes precedence over the file.

# Pi SSH target.
PI_SSH_HOST=192.168.1.42
PI_SSH_USER=stefan
PI_SSH_PORT=22

# SSH password. Keep this ONLY in deploy.env (git-ignored) — never commit it.
PI_SSH_PASSWORD=

# Path to the checkout on the Pi that holds docker-compose.yml.
PI_REPO_PATH=/home/stefan/git/BirdScanner
