# Models not used by the running detector. The detector only needs
# src/local/convnext_v2_tiny_int8.onnx; everything else here is training/
# conversion scratch that must not be copied into the image (155MB -> seconds).
# NOTE: bare `local/` is anchored at the context root and does NOT match
# `src/local/`, so the unused models must be listed by their full path.
src/local/convnext_v2_tiny.onnx
src/local/yolov8s.onnx
src/local/imx500_network_yolo11n_pp.rpk
src/local/converted5/
*.egg-info/
dist/
